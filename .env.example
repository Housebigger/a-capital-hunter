# Capital flow data source: "tushare" (default) or "jqdata".
# Tushare is the default: no region restriction, and moneyflow is reachable
# with a free 2000-point account. Use "jqdata" only if you have purchased
# JQData's paid money-flow module (its base account cannot access it).
CAPITAL_FLOW_SOURCE=tushare

# --- Tushare Pro (default source) ---
# Get a free token at https://tushare.pro/register (no region restriction).
# moneyflow_dc (direct main-force net inflow) needs 5000 points; if your
# account lacks it, the syncer auto-degrades to moneyflow (2000 points) and
# computes main force from super-large + large order buy/sell.
TUSHARE_TOKEN=

# --- JQData (alternative source, paid money-flow module) ---
# Register at https://www.joinquant.com — mainland China network required,
# AND the money-flow (get_money_flow) interface is a paid module.
JQDATA_USERNAME=
JQDATA_PASSWORD=

# SQLite snapshot database path (default: server/data/capital_flow.sqlite3)
CAPITAL_FLOW_DB=server/data/capital_flow.sqlite3
